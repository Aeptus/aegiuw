#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# aegiuw pre-push hook — thin shim. All policy lives in
# scripts/quality/registry.mjs; this file only invokes the runner.
#
# Git pipes "<local_ref> <local_sha> <remote_ref> <remote_sha>" per ref on
# stdin. We forward that to the runner so it can diff exactly the pushed
# range; if stdin is empty, the runner falls back to upstream → main → HEAD^.
set -e
exec node scripts/quality/runner.mjs --mode=prepush "$@"
